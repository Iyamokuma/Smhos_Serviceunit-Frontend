# Public registration form + admin dashboard (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: edge function name for form submit (default: submit-registration)
# VITE_SUPABASE_FORM_SUBMIT_FN=submit-registration

# Supabase Edge Functions (set in Supabase dashboard / CLI secrets, not in Vite):
# ADMIN_JWT_SECRET=...
# SUPABASE_URL=...          (auto in Supabase)
# SUPABASE_SERVICE_ROLE_KEY=... (auto in Supabase)
# ADMIN_APP_URL=https://your-app.vercel.app/admin
# ADMIN_EMAIL_INVITES=false  # only set to disable invite-only admin creation (default: on)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Salvation Ministries <admin@yourdomain.com>
