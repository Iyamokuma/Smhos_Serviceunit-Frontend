# Salvation Ministries — Service Unit Frontend
# Copy to .env and fill in when the API repository is deployed.

# --- API connection (required for live data) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: edge function name for public form submit (default: submit-registration)
# VITE_SUPABASE_FORM_SUBMIT_FN=submit-registration

# --- Preview mode ---
# When Supabase variables are missing, the app runs in preview mode automatically:
#   • Registration form UI works with sample directory data
#   • Submissions are not sent to the server
#   • Admin sign-in requires the API variables above
# Set to "false" to disable preview behaviour even during local development.
# VITE_APP_PREVIEW=true

# Backend secrets (ADMIN_JWT_SECRET, RESEND_API_KEY, etc.) belong in the API
# repository and Supabase project settings — not in this frontend .env file.
